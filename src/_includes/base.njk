<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — {{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  <!-- Google AdSense — uncomment and add your publisher ID when approved -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8350556723025693" crossorigin="anonymous"></script>
</head>
<body>
  <header class="site-header">
    <nav>
      <a href="{{ '/' | url }}" class="logo">⚡ {{ site.title }}</a>
      <div class="nav-links">
        <a href="{{ '/articles/' | url }}">Tutorials</a>
        <a href="{{ '/courses/kubernetes-for-app-devs/' | url }}">Courses</a>
        <a href="{{ '/video-scripts/' | url }}">Video Scripts</a>
        <a href="{{ '/resources/' | url }}">Resources</a>
        <a href="{{ '/about/' | url }}">About</a>
        <a href="https://github.com/techai-explained/techai-explained">GitHub</a>
      </div>
    </nav>
  </header>
  <!-- Google AdSense Header Banner -->
  <div class="ad-slot ad-header" style="text-align:center;padding:10px 0;background:#f8f9fa;border-bottom:1px solid #eee;">
    <!-- TODO: Replace with AdSense ad unit code after approval -->
    <div style="width:728px;max-width:100%;height:90px;margin:0 auto;background:#eee;border:1px dashed #ccc;display:flex;align-items:center;justify-content:center;color:#999;font-size:13px;font-family:system-ui;">
      📢 Header Ad — Replace with AdSense code
    </div>
  </div>
  <div class="content-with-sidebar" style="display:flex;max-width:1200px;margin:0 auto;gap:24px;padding:0 16px;">
    <main style="flex:1;min-width:0;">
      {{ content | safe }}
      <!-- In-Article Ad (after content) -->
      <div class="ad-slot ad-in-article" style="text-align:center;padding:20px 0;margin:30px 0;">
        <!-- TODO: Replace with AdSense in-article ad unit -->
        <div style="width:100%;max-width:336px;height:280px;margin:0 auto;background:#f5f5f5;border:1px dashed #ccc;display:flex;align-items:center;justify-content:center;color:#999;font-size:13px;font-family:system-ui;">
          📢 In-Article Ad — Replace with AdSense code
        </div>
      </div>
    </main>
    <aside class="ad-sidebar" style="width:300px;flex-shrink:0;">
      <!-- Sidebar Ad -->
      <div class="ad-slot ad-sidebar-sticky" style="position:sticky;top:20px;text-align:center;">
        <!-- TODO: Replace with AdSense sidebar ad unit -->
        <div style="width:300px;height:250px;background:#f5f5f5;border:1px dashed #ccc;display:flex;align-items:center;justify-content:center;color:#999;font-size:13px;font-family:system-ui;">
          📢 Sidebar Ad — Replace with AdSense code
        </div>
      </div>
    </aside>
  </div>
  <footer>
    <p>&copy; {{ site.title }} Team — Complex tech, simple explanations.</p>
  </footer>
</body>
</html>
